# Copy this file to .env.local and fill in your values

# Auth
JWT_SECRET=change-me-in-production

# Paystack (https://dashboard.paystack.com → Settings → API Keys)
PAYSTACK_SECRET_KEY=your-paystack-secret-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# AWS S3 (for product image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=af-south-1
S3_BUCKET=reneri-couture-assets
CLOUDFRONT_URL=https://dxxxxxxxxxxxxxxx.cloudfront.net

# Email / SMTP (AWS SES recommended)
# SES SMTP credentials from: AWS Console → SES → SMTP Settings → Create SMTP credentials
SMTP_HOST=email-smtp.af-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-username
SMTP_PASS=your-ses-smtp-password
SMTP_FROM=orders@renericouture.com
